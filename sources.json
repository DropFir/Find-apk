{
  "searchPolicy": {
    "mode": "fast",
    "perSourceTimeoutSeconds": 20,
    "stopSearchAtSeconds": 120,
    "perKeywordTimeoutSeconds": 150,
    "directDownloadTimeoutSeconds": 20,
    "directDownloadRetries": 1,
    "largePackageThresholdBytes": 52428800,
    "largePackageTimeoutSeconds": 60,
    "persistPartialAcrossCommands": true,
    "resumePersistedPartialOnceBeforeBrowser": true,
    "extractDownloadLinkBeforeDeclaringBlocked": true,
    "exactPagePipelineTool": "tools/download_from_page.py",
    "exactPagePipelineRequired": true,
    "manualExactPageRegexForbidden": true,
    "partialBatchResponseCannotSupportNoLink": true,
    "userProvidedExactUrlPriority": true,
    "realChromeFallbackAfterDirectDownloadFailure": true,
    "browserRequiredSources": [
      "APKPure",
      "APKCombo",
      "Uptodown"
    ],
    "downloadLinkFailureCannotBeReportedAsNoLink": true,
    "visibleCaptchaEvidenceRequired": true,
    "passiveCaptchaAssetsAreNotBlockers": true,
    "multiKeywordBatchQueries": true,
    "buildConfiguredSourceSearchesFirst": true,
    "requireAllEnabledSourcesQueriedBeforeNoResult": true,
    "sourceStatusVocabulary": [
      "unchecked",
      "partially_queried",
      "queried",
      "candidate_found",
      "exact_page_verified",
      "download_attempted"
    ],
    "historyEvidenceRequiredForCoverageClaims": true,
    "preferredSourceCandidateMustBeVerifiedFirst": true,
    "separateKeywordAndPackageQueriesRequired": true,
    "combinedKeywordPackageQueryDoesNotCount": true,
    "webToolOpenFailureIsNotSourceFailure": true,
    "probeSearchUrlAfterToolOpenFailure": true,
    "genericSearchRedirectCannotCountAsCompletedQuery": true,
    "externalSearchTimeoutCannotSupportNoCandidate": true,
    "retryFailedBatchAsSeparateQueriesOnce": true,
    "searchCandidateTool": "tools/extract_search_candidates.py",
    "searchCandidateToolRequiredForSearchUrls": true,
    "probeOkDoesNotCompleteSearch": true,
    "candidateFoundMustBeVerifiedBeforeBrowserOrNextSource": true,
    "downloadNoteForbiddenWhileCandidateUnverified": true,
    "onCloudflareChallenge": "externalQueryThenRealChromeThenCloudflareFaker",
    "automaticBrowserFallback": true,
    "batchIndependentQueries": true,
    "stopAfterFirstCurrentPackage": true,
    "oldVersionAction": "downloadHighestTrustedAvailableVersion"
  },
  "searchPagePolicy": {
    "tool": "tools/extract_search_candidates.py",
    "requireExactPackageMatch": true,
    "candidateFoundAction": "verifyExactPageImmediately",
    "genericSearchRedirectAction": "runExternalFallback",
    "networkErrorStatus": "unchecked",
    "probeOkRequiresCandidateExtraction": true,
    "browserSearchForbiddenAfterProbeOk": true
  },
  "identitySelectionPolicy": {
    "askUserOnAmbiguousKeyword": false,
    "continueWithoutClarification": true,
    "reusePreviouslyVerifiedIdentityForSameKeyword": true,
    "ranking": [
      "user_supplied_identity",
      "previously_verified_same_keyword_identity",
      "google_play_and_official_site_match",
      "exact_title_active_listing_recent_update",
      "strongest_complete_official_evidence"
    ],
    "reportAutomaticChoiceInFinal": true
  },
  "versionSelectionPolicy": {
    "defaultMode": "prefer-latest",
    "identityLookupVersionIsReferenceOnly": true,
    "acceptNewerThanReference": true,
    "acceptOlderWhenLatestUnavailable": true,
    "selectHighestDownloadableStableVersion": true,
    "strictOnlyWhenUserSpecifiesVersion": true,
    "strictToolArgument": "--version-policy exact",
    "reportAndNameUsingDetectedVersion": true
  },
  "downloadPagePolicy": {
    "signedLinkPrefixes": [
      "/r2?u=",
      "/d?u="
    ],
    "downloadSignedLinksImmediately": true,
    "manualEntryMustUseBlockedPage": true,
    "apkpureDetailToDownloadTransition": "automatic",
    "apkpureTransitionTool": "tools/download_from_page.py",
    "browserOnlyAfterApkpureDownloadPageFails": true,
    "browserMustOpenApkpureDownloadPage": true,
    "apkmirrorVariantToFileTransition": "automatic",
    "apkmirrorTransitionTool": "tools/download_from_page.py",
    "sharedNavigationHeaders": "tools/http_headers.py",
    "networkTimeoutRequiresActualTimeoutEvidence": true
  },
  "cloudflareFallback": {
    "enabled": true,
    "requiredForPublicPages": true,
    "strategy": "realChromeThenCloudflareFakerThenNextSource",
    "realChromeFirst": true,
    "realChromeTimeoutSeconds": 45,
    "reuseSameBrowserSession": true,
    "exportBrowserCookies": false,
    "repository": "https://github.com/onlyGuo/Cloudflare-Faker.git",
    "pinnedCommit": "5b0f2a4759d7b84c36e37afbe5c2e6400706b6c6",
    "localDirectory": "tools/vendor/Cloudflare-Faker",
    "cloudflareFakerTimeoutSeconds": 45,
    "totalFallbackTimeoutSeconds": 75,
    "setupOutsideKeywordTimer": true,
    "reuseDomainCookies": true,
    "localhostOnly": true,
    "allowedPageTypes": [
      "public_search",
      "public_app_detail",
      "public_download"
    ],
    "forbiddenPageTypes": [
      "login",
      "payment",
      "account",
      "admin",
      "permissioned"
    ],
    "failureStates": [
      "chrome_unavailable",
      "interactive_challenge_pending",
      "faker_prerequisite_missing",
      "challenge_timeout",
      "page_still_blocked",
      "browser_required",
      "cdn_connection_failed",
      "no_download_link",
      "download_failed"
    ]
  },
  "preferredSources": [
    {
      "name": "APKPure",
      "baseUrl": "https://apkpure.com",
      "searchUrlTemplate": "https://apkpure.com/search?q={query}",
      "homepageRequired": false,
      "enabled": true
    },
    {
      "name": "APKPac Canada",
      "baseUrl": "https://ca.apkpac.com",
      "searchUrlTemplate": "https://ca.apkpac.com/search?q={query}",
      "homepageRequired": false,
      "enabled": true
    },
    {
      "name": "APKCombo",
      "baseUrl": "https://apkcombo.com",
      "searchUrlTemplate": "https://apkcombo.com/search?q={query}",
      "homepageRequired": false,
      "enabled": true
    },
    {
      "name": "APKMirror",
      "baseUrl": "https://www.apkmirror.com",
      "searchMode": "externalSiteQuery",
      "homepageRequired": false,
      "enabled": true
    },
    {
      "name": "CNET Download",
      "baseUrl": "https://download.cnet.com",
      "searchMode": "externalSiteQuery",
      "homepageRequired": false,
      "enabled": true
    }
  ],
  "fallbackSearch": {
    "enabled": true,
    "onlyAfterPreferredSourcesExhausted": true,
    "providers": [
      "Google",
      "Bing"
    ]
  }
}
